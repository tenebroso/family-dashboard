generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:../dev.db"
}

model Person {
  id        String     @id @default(cuid())
  name      String
  color     String
  googleId  String?    @unique
  email     String?    @unique
  chores    Chore[]
  reminders Reminder[]
  athlete   Athlete?
  createdAt DateTime   @default(now())
}

model Chore {
  id          String            @id @default(cuid())
  title       String
  personId    String
  person      Person            @relation(fields: [personId], references: [id])
  dayOfWeek   String            @default("[]")
  oneTimeDate String?
  isActive    Boolean           @default(true)
  completions ChoreCompletion[]
  createdAt   DateTime          @default(now())
}

model ChoreCompletion {
  id          String   @id @default(cuid())
  choreId     String
  chore       Chore    @relation(fields: [choreId], references: [id])
  completedAt DateTime @default(now())
  dateKey     String

  @@unique([choreId, dateKey])
}

model Message {
  id         String   @id @default(cuid())
  personSlug String
  body       String
  parsedType String?
  parsedDone Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model WordOfDay {
  id           String @id @default(cuid())
  word         String
  definition   String
  partOfSpeech String
  dateKey      String @unique
}

model Track {
  id       String  @id @default(cuid())
  title    String
  artist   String
  filename String  @unique
  dateKey  String?
}

model Reminder {
  id        String   @id @default(cuid())
  personId  String
  person    Person   @relation(fields: [personId], references: [id])
  text      String
  dueDate   String?
  done      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model GroceryItem {
  id        String   @id @default(cuid())
  name      String
  quantity  String?
  category  String?
  addedBy   String
  checked   Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Athlete {
  id            String         @id @default(cuid())
  personId      String         @unique
  person        Person         @relation(fields: [personId], references: [id], onDelete: Cascade)
  trainingWeeks TrainingWeek[]
  createdAt     DateTime       @default(now())
}

model TrainingWeek {
  id        String    @id @default(cuid())
  athleteId String
  athlete   Athlete   @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  weekOf    String
  pdfUrl    String?
  workouts  Workout[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([athleteId, weekOf])
}

model Workout {
  id             String             @id @default(cuid())
  trainingWeekId String
  trainingWeek   TrainingWeek       @relation(fields: [trainingWeekId], references: [id], onDelete: Cascade)
  date           String
  dayOfWeek      Int
  type           String
  exercises      StrengthExercise[]
  runWorkout     RunWorkout?
  notes          String?
  completedAt    DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
}

model StrengthExercise {
  id          String        @id @default(cuid())
  workoutId   String
  workout     Workout       @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  name        String
  section     String
  order       Int
  loadingNote String?
  sets        StrengthSet[]
  createdAt   DateTime      @default(now())
}

model StrengthSet {
  id           String           @id @default(cuid())
  exerciseId   String
  exercise     StrengthExercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  setNumber    Int
  targetReps   String?
  targetWeight Float?
  targetRPE    String?
  tempo        String?
  actualReps   String?
  actualWeight Float?
  actualRPE    String?
  notes        String?
  completed    Boolean          @default(false)
  completedAt  DateTime?
}

model RunWorkout {
  id            String    @id @default(cuid())
  workoutId     String    @unique
  workout       Workout   @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  targetMiles   Float?
  targetPace    String?
  heartRateZone String?
  actualMiles   Float?
  actualTime    Int?
  avgHeartRate  Int?
  maxHeartRate  Int?
  actualRPE     Int?
  notes         String?
  completed     Boolean   @default(false)
  completedAt   DateTime?
}
